{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@shibanet0/datamitsu-config/tsconfig/react-library.json",
  "compilerOptions": {
    "types": ["@testing-library/jest-dom/vitest"],
    "outDir": "dist",
    "sourceMap": false,
    "noEmit": false,
    "declaration": true,
    "declarationMap": false,
    "jsx": "react-jsx"
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx*"]
}
