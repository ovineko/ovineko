{
  "$schema": "../../.datamitsu/oxlint_configuration_schema.json",
  "categories": {
    "correctness": "error",
    "pedantic": "error",
    "perf": "error",
    "style": "warn",
    "suspicious": "error"
  },
  "rules": {
    "new-cap": "off",
    "max-statements": "off",
    "no-shadow": "off",
    "no-duplicate-imports": "off",
    "unicorn/prefer-top-level-await": "off",
    "typescript/no-extraneous-class": "off"
  },
  "extends": ["../../.datamitsu/.oxlintrc.json"]
}
