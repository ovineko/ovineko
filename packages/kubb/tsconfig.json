{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@shibanet0/datamitsu-config/tsconfig/library.json",
  "compilerOptions": {
    "outDir": "dist",
    "module": "preserve",
    "sourceMap": false,
    "noEmit": false,
    "declaration": true,
    "declarationMap": false,
    "moduleResolution": "bundler",
    "types": ["node"]
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts*"]
}
